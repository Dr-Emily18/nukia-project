# ─────────────────────────────────────────────────────────
# NUKIA v2.0 Environment Variables
# Copy this to .env and fill in real values
# NEVER commit .env to GitHub
# ─────────────────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=production

# Database — Render gives you this automatically
DATABASE_URL=postgresql://user:password@host:5432/nukia

# WhatsApp — from twilio.com console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# SMS — from africastalking.com
AT_USERNAME=sandbox
AT_API_KEY=your_api_key
AT_SENDER_ID=NUKIA

# Security — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FORMULA_ENCRYPTION_KEY=your_64_char_hex_key_here

# Admin panel password — choose anything
ADMIN_SECRET=choose-a-strong-password

# Printer bridge key — choose anything
BRIDGE_API_KEY=choose-another-strong-password

# Your M-Pesa number sellers pay to
MPESA_BUSINESS_NUMBER=+255700000000

# Credits
COST_PER_MIX=200
FREE_TRIAL_CREDITS=50
